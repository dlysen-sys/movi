# MoVi license backend — SERVER-SIDE. Never commit the real .env.
PORT=8090

# Frontend origin(s) for CORS. Comma-separated, or * for dev.
CORS_ORIGIN=https://movicommunity.com

# Chain — admin auth reads movi.sol checkIsAdmin(); claim reads isActive().
BSC_RPC_URL=https://bsc-dataseed1.binance.org
MOVI_ADDRESS=
# Fallback admin allowlist (comma-separated) used ONLY while MOVI_ADDRESS is empty (pre-deploy dev).
ADMIN_ADDRESSES=

# License policy
LICENSE_VALID_DAYS=30
LICENSE_SELF_CLAIM=false

# Ops
RATE_LIMIT_PER_MIN=20
AUTH_MAX_AGE_SEC=300
DATA_FILE=./data/licenses.json

# Optional public HTTPS via Cloudflare Tunnel (see docker-compose.yml)
TUNNEL_TOKEN=
